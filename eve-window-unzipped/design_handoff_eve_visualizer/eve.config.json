{
  // ============================================================
  //  EVE — Voice Visualizer configuration
  //  Edit these values to retune the look & behaviour of the orb.
  //  This file is JSONC (JSON + // comments). The component strips
  //  the comments before parsing, so standard JSON.parse users can
  //  remove them. Every key below is optional — anything you omit
  //  falls back to the built-in default.
  // ============================================================

  // -- Window shell -------------------------------------------------
  "window": {
    "width": 372,          // px — width of the glass panel
    "height": 300,         // px — height of the canvas region (the orb stage)
    "cornerRadius": 22     // px — panel corner rounding
  },

  // -- Color -------------------------------------------------------
  // Which palette to use at startup. One of the keys in "palettes".
  "defaultAccent": "amber",

  // Color sets for the neural sphere. Add your own by copying a block.
  //   edge = connection lines · node = particle dots
  //   core = bright center / signal heads · ring = orbital rings & HUD
  //   hex  = solid accent used by buttons & status (no transparency)
  "palettes": {
    "amber":  { "edge": "#ff8c1a", "node": "#ffcf7a", "core": "#ffe7b8", "ring": "#ffb347", "hex": "#ffb65e" },
    "cyan":   { "edge": "#1fb0e0", "node": "#8fe9ff", "core": "#d8fbff", "ring": "#52d4f0", "hex": "#6fdcf5" },
    "violet": { "edge": "#8a6cff", "node": "#c4b3ff", "core": "#ece4ff", "ring": "#a98cff", "hex": "#b49cff" },
    "mono":   { "edge": "#9fb0c8", "node": "#e3ebf5", "core": "#ffffff", "ring": "#b8c6da", "hex": "#cdd8e6" }
  },

  // -- Particle sphere ---------------------------------------------
  "particleCount": 150,    // number of nodes on the sphere (80–240 reasonable)
  "neighbors": 3,          // neural edges drawn from each node to its N nearest

  // -- Depth of field (3D back-blur) -------------------------------
  // Far particles render soft/bokeh; near particles stay crisp.
  "depthOfField": {
    "enabled": true,
    "nearPlane": 0.82,     // depth (0=back, 1=front) at/above which nodes are fully sharp
    "maxBlur": 7,          // px — blur radius applied to the farthest nodes
    "farDim": 0.45         // 0–1 — how much to fade the most distant nodes (higher = dimmer back)
  },

  // -- Motion ------------------------------------------------------
  "rotation": {
    "yaw": 0.16,           // horizontal spin speed (radians/sec)
    "pitchBase": 0.34,     // resting tilt of the sphere
    "pitchWobble": 0.14    // gentle up/down sway amount
  },

  // -- Per-state energy --------------------------------------------
  // pulses    = how many signals travel the network at once
  // brightness = overall pulse intensity (0–1)
  "states": {
    "idle":      { "pulses": 12, "brightness": 0.5 },
    "listening": { "pulses": 20, "brightness": 0.8 },
    "thinking":  { "pulses": 16, "brightness": 0.7 },
    "speaking":  { "pulses": 30, "brightness": 1.0 }
  },

  // -- Demo timings (the canned "reply" used by the buttons) -------
  "timings": {
    "thinkingDelayMs": 650,   // pause on "Thinking…" before Eve starts speaking
    "replyDurationMs": 3200   // how long the demo speaking burst lasts
  }
}
