# ─── EVE configuration ───────────────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env` (it's gitignored).

# ── LLM (provider-agnostic) ──────────────────────────────────────────────────
# EVE is not tied to any single vendor. Pick a provider + model and EVE works.
# LLM_MODEL is a LiteLLM model string, e.g.:
#   anthropic/claude-opus-4-8 | openai/gpt-4o | gemini/gemini-1.5-pro | ollama/llama3
LLM_PROVIDER=anthropic
LLM_MODEL=anthropic/claude-opus-4-8
# Generic key the factory maps onto the chosen provider:
LLM_API_KEY=
# Optional: only needed for self-hosted / local models (e.g. Ollama):
LLM_API_BASE=

# You may instead set the provider's own env var; LiteLLM reads these directly:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Embedder (vectorizes memories — separate from the LLM) ────────────────────
# FastEmbed (ONNX) runs in-process; the model is downloaded and cached on first
# run. EMBEDDING_DIMS must match the model's output size. List the models + dims:
#   python -c "from fastembed import TextEmbedding as T; [print(m['model'], m['dim']) for m in T.list_supported_models()]"
EMBEDDER_PROVIDER=fastembed
EMBEDDER_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMS=768

# ── Memory store (on-disk FAISS index) ────────────────────────────────────────
# Where long-term memory persists (FAISS index + metadata). "~" expands and the
# directory is created on first use; delete its contents to wipe long-term memory.
MEMORY_DIR=~/.eve/memory

# ── Speech-to-text (local Whisper) ───────────────────────────────────────────
WHISPER_MODEL=base          # tiny | base | small | medium | large
WHISPER_DEVICE=auto         # auto | cpu | cuda
TTS_VOICE=                  # part of a local voice name, e.g. Samantha (blank = auto)
VOICE_INPUT=vad             # vad = always listening | ptt = push-to-talk | wake = wake word

# ── Text-to-speech: ElevenLabs (optional, cloud) ─────────────────────────────
# Leave ELEVENLABS_API_KEY blank to use the local (pyttsx3) voice. Set it to use
# ElevenLabs cloud voices (incl. your own cloned voice); EVE falls back to the
# local voice automatically if the key is missing or a request fails.
# Get a key at https://elevenlabs.io → Profile → API Keys.
ELEVENLABS_API_KEY=
# Voice id from your library: elevenlabs.io → Voices → ⋯ → "Copy voice ID".
# List them anytime with: python -m eve.pipeline.tts
# Default below is the stock "Rachel" voice.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Low latency: eleven_flash_v2_5 (fastest) | eleven_turbo_v2_5 | eleven_multilingual_v2 (best quality, slower)
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Wake word (only used when VOICE_INPUT=wake; needs `pip install openwakeword`) ─
# Built-in name (alexa | hey_jarvis | hey_mycroft | hey_rhasspy) or a path to a
# custom .onnx/.tflite model you trained for "Hey EVE".
WAKE_WORD=hey_jarvis
WAKE_THRESHOLD=0.5          # 0..1 detection score; raise to reduce false wakes

# ── Google Workspace tools (optional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_TOKEN_PATH=./.secrets/google_token.json

# ── Web search (Tavily — live internet lookup for the web_search tool) ────────
# Free key at https://app.tavily.com. Without it, the tool is still listed but
# returns a friendly "not configured" error if the model calls it.
TAVILY_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── Self-improvement loop (sleep-time compute) ────────────────────────────────
# When enabled, EVE uses idle time (no conversation for IMPROVE_IDLE_SECONDS) to
# run a heavier local model that researches, implements, and test-gates small
# improvements to EVE's own codebase. All changes land on a `self-improve/*`
# branch inside a sandbox git worktree — NEVER on main — and EVE's persistent
# memory (MEMORY_DIR) is mechanically untouchable. Every cycle is journaled
# under IMPROVE_HOME/journal. Requires a local Ollama model, e.g.:
#   ollama pull ornith:35b
SELF_IMPROVE=false
IMPROVE_MODEL=ollama_chat/ornith:35b
IMPROVE_IDLE_SECONDS=180    # no EVE conversation for this long before a cycle
                            # starts ("idle" = not talking to EVE; other computer
                            # use is never monitored and never resets the timer)
IMPROVE_MAX_FILES=10        # per-cycle changed-file budget
IMPROVE_MAX_CYCLES=0        # per-session cycle cap (0 = unlimited)
IMPROVE_HOME=~/.eve/improve # journal, state, and sandbox worktrees live here
IMPROVE_REFLECT_HOURS=6     # min gap between memory reflections (0 disables)
